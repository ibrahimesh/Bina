@model CreatePropertyDto
@{
    ViewData["Title"] = "Elan Yerləşdir";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h3 class="mb-4">Yeni Elan</h3>
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger" asp-validation-summary="All"></div>
                    }
                    <form asp-controller="Elan" asp-action="Create" method="post" enctype="multipart/form-data">
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label class="form-label text-muted fw-bold">Elanın başlığı</label>
                                <input type="text" class="form-control" asp-for="Title" minlength="10" required />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label text-muted fw-bold">Qiymət (AZN)</label>
                                <input type="number" step="0.01" min="1" class="form-control" asp-for="Price" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fw-bold">Otaq sayı</label>
                                <input type="number" min="1" max="50" class="form-control" asp-for="RoomCount" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fw-bold">Sahə (m²)</label>
                                <input type="number" min="1" class="form-control" asp-for="Area" required />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label text-muted fw-bold">Mərtəbə</label>
                                <input type="number" min="1" class="form-control" asp-for="Floor" value="1" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fw-bold">Ümumi mərtəbə</label>
                                <input type="number" min="1" class="form-control" asp-for="TotalFloors" value="1" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fw-bold">Elan tipi</label>
                                <select class="form-select" asp-for="ListingType" required>
                                    <option value="1">Satılır</option>
                                    <option value="2">Kirayə</option>
                                    <option value="3">Günlük</option>
                                </select>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-bold">Şəhər (ID)</label>
                                <input type="number" class="form-control" asp-for="CityId" value="1" min="1" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-bold">Kateqoriya (ID)</label>
                                <input type="number" class="form-control" asp-for="CategoryId" value="1" min="1" required />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label class="form-label text-muted fw-bold">Ətraflı məlumat (Təsvir)</label>
                                <textarea class="form-control" rows="5" asp-for="Description" minlength="20" required></textarea>
                            </div>
                        </div>
                        <div class="text-end">
                            <button type="submit" class="btn btn-success fw-bold px-5">Elanı Göndər</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>