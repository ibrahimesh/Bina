@model CreatePropertyDto
@{
    ViewData["Title"] = "Elan Yerl??dir";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h3 class="mb-4">Yeni Elan</h3>
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger" asp-validation-summary="All"></div>
                    }
                    <form asp-controller="Elan" asp-action="Create" method="post" enctype="multipart/form-data">
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label class="form-label text-muted fw-bold">Elan?n ba?l???</label>
                                <input type="text" class="form-control" asp-for="Title" required />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label text-muted fw-bold">Qiym?t (AZN)</label>
                                <input type="number" step="0.01" class="form-control" asp-for="Price" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fw-bold">Otaq say?</label>
                                <input type="number" class="form-control" asp-for="RoomCount" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fw-bold">Sah? (m?)</label>
                                <input type="number" class="form-control" asp-for="Area" required />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-bold">??h?r (ID)</label>
                                <input type="number" class="form-control" asp-for="CityId" value="1" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-bold">Kateqoriya (ID)</label>
                                <input type="number" class="form-control" asp-for="CategoryId" value="1" required />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label class="form-label text-muted fw-bold">?trafl? m?lumat (T?svir)</label>
                                <textarea class="form-control" rows="5" asp-for="Description" required></textarea>
                            </div>
                        </div>
                        <div class="text-end">
                            <button type="submit" class="btn btn-success fw-bold px-5">Elan? G?nd?r</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>