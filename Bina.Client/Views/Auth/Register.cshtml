@model RegisterDto
@{
    ViewData["Title"] = "Qeydiyyat";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow border-0">
            <div class="card-header bg-danger text-white text-center">
                <h4 class="mb-0">Qeydiyyat</h4>
            </div>
            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <div asp-validation-summary="All"></div>
                    </div>
                }
                <form asp-controller="Auth" asp-action="Register" method="post">
                    <div class="mb-3">
                        <label class="form-label text-muted fw-bold">Ad və Soyad</label>
                        <input type="text" class="form-control" name="FullName" asp-for="FullName" minlength="2" maxlength="100" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted fw-bold">E-poçt</label>
                        <input type="email" class="form-control" name="Email" asp-for="Email" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted fw-bold">Mobil nömrə</label>
                        <input type="text" class="form-control" name="PhoneNumber" asp-for="PhoneNumber" placeholder="+994501234567" pattern="^\+994[0-9]{9}$" required />
                        <small class="text-muted">Format: +994501234567</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted fw-bold">Şifrə</label>
                        <input type="password" class="form-control" name="Password" asp-for="Password" minlength="8" required />
                        <small class="text-muted">Ən azı 8 simvol, 1 böyük hərf, 1 kiçik hərf, 1 rəqəm, 1 xüsusi simvol.</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted fw-bold">Şifrənin təkrarı</label>
                        <input type="password" class="form-control" name="ConfirmPassword" asp-for="ConfirmPassword" required />
                    </div>
                    <button type="submit" class="btn btn-success w-100 fw-bold py-2">Hesab Yarat</button>
                    <div class="text-center mt-3">
                        Təzədən <a asp-controller="Auth" asp-action="Login" class="text-danger fw-bold text-decoration-none">daxil ol</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>